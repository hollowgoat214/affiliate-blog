---
interface Props {
  name: string;
  description: string;
  image: string;
  url: string;
  price?: string;
  badge?: string;
}
const { name, description, image, url, price, badge } = Astro.props;
---

<div class="affiliate-card not-prose flex flex-col sm:flex-row">
  <!-- Image -->
  <div class="sm:w-44 flex-shrink-0 flex items-center justify-center p-5" style="background: #0e0e0e; border-right: 1px solid rgba(245,158,11,0.1);">
    <img
      src={image}
      alt={name}
      width="160"
      height="160"
      class="w-32 h-32 object-contain"
      loading="lazy"
      decoding="async"
    />
  </div>

  <!-- Details -->
  <div class="p-5 flex flex-col justify-between flex-1 min-w-0">
    <div>
      {badge && (
        <span class="inline-block text-xs font-black px-2.5 py-0.5 rounded mb-2.5 uppercase tracking-widest" style="background: var(--accent); color: #000;">
          {badge}
        </span>
      )}
      <h4 class="font-bold text-lg mb-0.5" style="color: var(--text);">{name}</h4>
      {price && <p class="font-semibold mb-2 text-sm" style="color: var(--accent);">{price}</p>}
      <p class="text-sm leading-relaxed" style="color: var(--text-muted);">{description}</p>
    </div>

    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer nofollow sponsored"
      class="btn-primary mt-4 self-start"
    >
      Check Price on Amazon
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
      </svg>
    </a>
  </div>
</div>
