---
interface Props {
  name: string;
  description: string;
  image: string;
  url: string;
  price?: string;
  badge?: string;
}
const { name, description, image, url, price, badge } = Astro.props;
---

<div class="aff-card not-prose" style="display:flex;flex-direction:column;">
  <div style="display:flex;flex-direction:column;" class="aff-inner">
    <!-- image -->
    <div style="flex-shrink:0;width:100%;max-height:160px;background:var(--surface2);display:flex;align-items:center;justify-content:center;padding:1.5rem;border-bottom:1px solid var(--border);">
      <img src={image} alt={name} width="140" height="140" style="width:auto;height:120px;max-width:140px;object-fit:contain;" loading="lazy" decoding="async"/>
    </div>

    <!-- details -->
    <div style="padding:1.25rem;display:flex;flex-direction:column;flex:1;">
      {badge && (
        <span style="display:inline-block;font-size:.6rem;font-weight:900;letter-spacing:.12em;text-transform:uppercase;padding:.2rem .65rem;border-radius:4px;background:var(--accent);color:#000;margin-bottom:.75rem;width:fit-content;">
          {badge}
        </span>
      )}
      <h4 style="font-size:1rem;font-weight:800;color:var(--text);margin-bottom:.25rem;letter-spacing:-.01em;">{name}</h4>
      {price && <p style="font-size:.85rem;font-weight:700;color:var(--accent);margin-bottom:.5rem;">{price}</p>}
      <p style="font-size:.83rem;line-height:1.65;color:var(--muted);flex:1;">{description}</p>

      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer nofollow sponsored"
        class="btn btn-primary"
        style="margin-top:1.125rem;justify-content:center;font-size:.82rem;"
      >
        Check Price on Amazon
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
        </svg>
      </a>
    </div>
  </div>
</div>

<style>
  @media (min-width: 520px) {
    .aff-inner {
      flex-direction: row !important;
    }
    .aff-inner > div:first-child {
      width: 160px !important;
      max-height: none !important;
      border-bottom: none !important;
      border-right: 1px solid var(--border) !important;
    }
  }
</style>
