---
interface Props {
  title: string;
  description: string;
  slug: string;
  heroImage?: string;
  heroImageAlt?: string;
  category: string;
  pubDate: Date;
  featured?: boolean;
}

const { title, description, slug, heroImage, heroImageAlt, category, pubDate } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group flex flex-col h-full bg-[#161616] border border-[#2a2a2a] rounded-xl overflow-hidden hover:border-amber-500/30 transition-all duration-300">
  <!-- Thumbnail -->
  {heroImage ? (
    <a href={`/blog/${slug}`} class="block aspect-video overflow-hidden bg-zinc-900 flex-shrink-0">
      <img
        src={heroImage}
        alt={heroImageAlt || title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
        decoding="async"
        width="640"
        height="360"
      />
    </a>
  ) : (
    <a href={`/blog/${slug}`} class="block aspect-video bg-gradient-to-br from-zinc-900 to-zinc-800 flex-shrink-0 flex items-center justify-center">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-zinc-700">
        <rect x="3" y="3" width="18" height="18" rx="2"/>
        <circle cx="8.5" cy="8.5" r="1.5"/>
        <path d="M21 15l-5-5L5 21"/>
      </svg>
    </a>
  )}

  <!-- Content -->
  <div class="p-5 flex flex-col flex-1">
    <div class="flex items-center gap-2 mb-3">
      <a
        href={`/category/${category}`}
        class="text-xs font-semibold px-2.5 py-1 rounded-full bg-amber-500/10 text-amber-400 border border-amber-500/20 hover:bg-amber-500/20 transition-colors"
      >
        {category}
      </a>
      <time datetime={pubDate.toISOString()} class="text-xs text-zinc-600 ml-auto">
        {formattedDate}
      </time>
    </div>

    <h3 class="font-bold text-zinc-100 mb-2 leading-snug line-clamp-2 group-hover:text-amber-400 transition-colors">
      <a href={`/blog/${slug}`}>{title}</a>
    </h3>

    <p class="text-zinc-400 text-sm leading-relaxed line-clamp-3 flex-1">{description}</p>

    <a
      href={`/blog/${slug}`}
      class="mt-4 inline-flex items-center gap-1.5 text-amber-500 hover:text-amber-400 text-sm font-medium transition-colors w-fit"
    >
      Read more
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</article>
