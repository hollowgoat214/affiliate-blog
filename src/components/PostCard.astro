---
interface Props {
  title: string;
  description: string;
  slug: string;
  heroImage?: string;
  heroImageAlt?: string;
  category: string;
  pubDate: Date;
  placeholder?: boolean;
  index?: number;
}

const { title, description, slug, heroImage, heroImageAlt, category, pubDate, placeholder = false, index = 0 } = Astro.props;
const date  = pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const delay = `${Math.min(index * 0.08, 0.4)}s`;
---

<article
  class="post-card reveal"
  style={`transition-delay:${delay};`}
  data-magnetic
>
  <a href={`/blog/${slug}`} class="post-card-img block" tabindex="-1" aria-hidden="true">
    {heroImage ? (
      <img
        src={heroImage}
        alt={heroImageAlt || title}
        width="640" height="360"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center" style="min-height:180px;background:var(--surface2);">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--border2)" stroke-width="1.5">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <path d="M21 15l-5-5L5 21"/>
        </svg>
      </div>
    )}

    {placeholder && (
      <div class="placeholder-ribbon">⚠ placeholder · demo content · not a real review ⚠</div>
    )}
  </a>

  <div class="p-5 flex flex-col flex-1">
    <div class="flex items-center gap-2 mb-3">
      <a href={`/category/${category}`} class="tag">{category}</a>
      <time datetime={pubDate.toISOString()} class="text-xs ml-auto" style="color:var(--dim);">{date}</time>
    </div>

    <h3 class="font-bold text-base leading-snug mb-2 line-clamp-2" style="color:#e8e2da;">
      <a href={`/blog/${slug}`} class="hover-amber-link">{title}</a>
    </h3>

    <p class="text-sm leading-relaxed line-clamp-3 flex-1" style="color:var(--muted);">{description}</p>

    <span class="mt-4 text-xs font-bold" style="color:var(--accent);">Read more →</span>
  </div>
</article>
