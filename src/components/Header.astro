---
const nav = [
  { href: '/category/Tech',      label: 'Tech' },
  { href: '/category/Trending',  label: 'Trending' },
  { href: '/category/Gear',      label: 'Gear' },
  { href: '/category/Lifestyle', label: 'Lifestyle' },
  { href: '/about',              label: 'About' },
];
const path = Astro.url.pathname;
---

<header class="sticky top-0 z-50" style="background: rgba(8,8,8,0.85); backdrop-filter: blur(12px); border-bottom: 1px solid #1a1a1a;">
  <div class="container flex items-center justify-between h-14">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group select-none">
      <div class="relative w-7 h-7 flex-shrink-0">
        <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
          <circle cx="14" cy="14" r="13" stroke="#f59e0b" stroke-width="1.5" opacity="0.3"/>
          <circle cx="14" cy="14" r="9"  stroke="#f59e0b" stroke-width="1.5" opacity="0.6"/>
          <circle cx="14" cy="14" r="5"  fill="#f59e0b"/>
          <!-- spokes -->
          <line x1="14" y1="1"  x2="14" y2="5"  stroke="#f59e0b" stroke-width="1.5" opacity="0.4"/>
          <line x1="14" y1="23" x2="14" y2="27" stroke="#f59e0b" stroke-width="1.5" opacity="0.4"/>
          <line x1="1"  y1="14" x2="5"  y2="14" stroke="#f59e0b" stroke-width="1.5" opacity="0.4"/>
          <line x1="23" y1="14" x2="27" y2="14" stroke="#f59e0b" stroke-width="1.5" opacity="0.4"/>
          <line x1="4.5"  y1="4.5"  x2="7.5"  y2="7.5"  stroke="#f59e0b" stroke-width="1.5" opacity="0.3"/>
          <line x1="20.5" y1="20.5" x2="23.5" y2="23.5" stroke="#f59e0b" stroke-width="1.5" opacity="0.3"/>
          <line x1="23.5" y1="4.5"  x2="20.5" y2="7.5"  stroke="#f59e0b" stroke-width="1.5" opacity="0.3"/>
          <line x1="4.5"  y1="23.5" x2="7.5"  y2="20.5" stroke="#f59e0b" stroke-width="1.5" opacity="0.3"/>
        </svg>
      </div>
      <span class="font-black text-base tracking-tight text-zinc-100 group-hover:text-white transition-colors">
        TUMBLEWEED<span class="text-amber-500">0220</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-0.5">
      {nav.map((link) => (
        <a
          href={link.href}
          class={`px-3 py-1.5 text-sm font-medium rounded-md transition-all duration-200 ${
            path.startsWith(link.href)
              ? 'text-amber-400 bg-amber-500/10'
              : 'text-zinc-500 hover:text-zinc-200 hover:bg-white/5'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Mobile toggle -->
    <button
      id="nav-btn"
      class="md:hidden p-2 rounded-md text-zinc-500 hover:text-zinc-200 hover:bg-white/5 transition-colors"
      aria-label="Menu"
      aria-expanded="false"
    >
      <svg id="icon-open"  width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg id="icon-close" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="hidden">
        <path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="nav-mobile" class="hidden md:hidden" style="border-top: 1px solid #1a1a1a;">
    <nav class="container py-3 flex flex-col gap-0.5">
      {nav.map((link) => (
        <a
          href={link.href}
          class={`px-3 py-2 text-sm font-medium rounded-md transition-all ${
            path.startsWith(link.href)
              ? 'text-amber-400 bg-amber-500/10'
              : 'text-zinc-500 hover:text-zinc-200 hover:bg-white/5'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const btn   = document.getElementById('nav-btn');
  const menu  = document.getElementById('nav-mobile');
  const open  = document.getElementById('icon-open');
  const close = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    open?.classList.toggle('hidden', !isOpen);
    close?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
