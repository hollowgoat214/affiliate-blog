---
const navLinks = [
  { href: '/category/Tech', label: 'Tech' },
  { href: '/category/Trending', label: 'Trending' },
  { href: '/category/Gear', label: 'Gear' },
  { href: '/category/Lifestyle', label: 'Lifestyle' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-[#0c0c0c]/90 backdrop-blur-sm border-b border-[#2a2a2a]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group flex-shrink-0">
      <svg width="24" height="24" viewBox="0 0 32 32" fill="none" class="text-amber-500">
        <polygon points="16,2 30,9 30,23 16,30 2,23 2,9" fill="currentColor" opacity="0.2" stroke="currentColor" stroke-width="1.5"/>
        <polygon points="16,8 24,12 24,20 16,24 8,20 8,12" fill="currentColor" opacity="0.5"/>
        <polygon points="16,12 20,14 20,18 16,20 12,18 12,14" fill="currentColor"/>
      </svg>
      <span class="text-lg font-bold text-zinc-100 group-hover:text-amber-400 transition-colors">ReviewHive</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`px-3 py-1.5 rounded-md text-sm font-medium transition-colors ${
            currentPath.startsWith(link.href)
              ? 'text-amber-400 bg-amber-500/10'
              : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/60'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 rounded-md text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800 transition-colors"
      aria-label="Toggle navigation"
      aria-expanded="false"
    >
      <svg id="icon-menu" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="hidden">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-[#2a2a2a] bg-[#0c0c0c]">
    <nav class="max-w-6xl mx-auto px-4 py-3 flex flex-col gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${
            currentPath.startsWith(link.href)
              ? 'text-amber-400 bg-amber-500/10'
              : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/60'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconMenu?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
