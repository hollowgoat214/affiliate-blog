---
const year = new Date().getFullYear();
const cats  = ['Tech','Trending','Gear','Lifestyle'];
---

<footer style="border-top:1px solid var(--border);background:var(--bg2);margin-top:0;">
  <div class="container" style="padding-top:3.5rem;padding-bottom:3rem;">
    <div style="display:grid;grid-template-columns:1fr;gap:2.5rem 2rem;" class="footer-grid">

      <!-- Brand -->
      <div>
        <a href="/" style="display:inline-flex;align-items:center;gap:.625rem;text-decoration:none;margin-bottom:1rem;" aria-label="Tumbleweed0220">
          <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:24px;height:24px;">
            <ellipse cx="18" cy="18" rx="15" ry="6.5" stroke="#e8a020" stroke-width="1.3" opacity=".8"/>
            <ellipse cx="18" cy="18" rx="15" ry="6.5" stroke="#e8a020" stroke-width="1.3" opacity=".45" transform="rotate(45 18 18)"/>
            <ellipse cx="18" cy="18" rx="15" ry="6.5" stroke="#e8a020" stroke-width="1.3" opacity=".45" transform="rotate(90 18 18)"/>
            <ellipse cx="18" cy="18" rx="15" ry="6.5" stroke="#e8a020" stroke-width="1.3" opacity=".45" transform="rotate(135 18 18)"/>
            <circle  cx="18" cy="18" r="3" fill="#e8a020"/>
          </svg>
          <span style="font-size:.8rem;font-weight:900;letter-spacing:-.02em;color:var(--muted);">
            TUMBLEWEED<span style="color:var(--accent);">0220</span>
          </span>
        </a>
        <p style="font-size:.78rem;line-height:1.7;color:var(--dim);max-width:240px;">
          Solo affiliate blog. One person's honest takes on products worth buying.
        </p>
        <div style="display:flex;gap:.25rem;margin-top:1.25rem;">
          {[
            { label:'X/Twitter', icon:'<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>' },
            { label:'Instagram', icon:'<rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="2" fill="none"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2" fill="none"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>' },
          ].map(s => (
            <a href="#" aria-label={s.label} class="footer-social">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" set:html={s.icon}></svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Links -->
      <div>
        <p style="font-size:.62rem;font-weight:900;letter-spacing:.14em;text-transform:uppercase;color:var(--dim);margin-bottom:1rem;">Categories</p>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:.625rem;">
          {cats.map(c => (
            <li><a href={`/category/${c}`} class="footer-link">{c}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <p style="font-size:.62rem;font-weight:900;letter-spacing:.14em;text-transform:uppercase;color:var(--dim);margin-bottom:1rem;">Site</p>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:.625rem;">
          {[['All Posts','/blog'],['About','/about'],['Disclosure','/disclosure']].map(([l,h]) => (
            <li><a href={h} class="footer-link">{l}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div style="border-top:1px solid var(--border);margin-top:2.5rem;padding-top:1.5rem;display:flex;flex-direction:column;gap:.5rem;align-items:center;text-align:center;">
      <p style="font-size:.68rem;color:var(--dim);">&copy; {year} Tumbleweed0220. All rights reserved.</p>
      <p style="font-size:.65rem;color:var(--dim);">
        <a href="/disclosure" class="footer-link">Affiliate Disclosure</a>
        {' · '}
        This site earns commissions on some purchases.
      </p>
    </div>
  </div>
</footer>

<style>
  @media (min-width: 640px) {
    .footer-grid { grid-template-columns: 2fr 1fr 1fr !important; }
  }
  .footer-link {
    font-size: .8rem; color: var(--dim); text-decoration: none; transition: color .2s;
  }
  .footer-link:hover { color: var(--accent); }
  .footer-social {
    padding: .5rem; border-radius: 6px;
    color: var(--dim); transition: color .2s, background .2s;
  }
  .footer-social:hover { color: var(--accent); background: var(--accent-dim); }
</style>
