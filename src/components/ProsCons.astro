---
interface Props { pros: string[]; cons: string[]; }
const { pros, cons } = Astro.props;
---
<div class="not-prose grid sm:grid-cols-2 gap-3">
  <div class="rounded-xl p-5" style="background:var(--green-dim);border:1px solid rgba(34,197,94,.2);">
    <p class="text-xs font-black uppercase tracking-widest mb-4 flex items-center gap-2" style="color:#22c55e;">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
      </svg>
      Pros
    </p>
    <ul class="space-y-2.5">
      {pros.map(p => (
        <li class="flex items-start gap-2 text-sm" style="color:#a0a090;">
          <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>{p}
        </li>
      ))}
    </ul>
  </div>
  <div class="rounded-xl p-5" style="background:var(--red-dim);border:1px solid rgba(239,68,68,.2);">
    <p class="text-xs font-black uppercase tracking-widest mb-4 flex items-center gap-2" style="color:#ef4444;">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
      Cons
    </p>
    <ul class="space-y-2.5">
      {cons.map(c => (
        <li class="flex items-start gap-2 text-sm" style="color:#a0a090;">
          <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>{c}
        </li>
      ))}
    </ul>
  </div>
</div>
