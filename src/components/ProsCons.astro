---
interface Props {
  pros: string[];
  cons: string[];
}

const { pros, cons } = Astro.props;
---

<div class="not-prose grid sm:grid-cols-2 gap-4">
  <!-- Pros -->
  <div class="bg-emerald-950/30 border border-emerald-800/30 rounded-xl p-5">
    <h4 class="font-bold text-emerald-400 mb-4 flex items-center gap-2 text-base">
      <span class="flex items-center justify-center w-5 h-5 rounded-full bg-emerald-500/20">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </span>
      Pros
    </h4>
    <ul class="space-y-2.5">
      {pros.map((pro) => (
        <li class="flex items-start gap-2.5 text-sm text-zinc-300">
          <svg class="w-4 h-4 text-emerald-500 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span>{pro}</span>
        </li>
      ))}
    </ul>
  </div>

  <!-- Cons -->
  <div class="bg-red-950/30 border border-red-800/30 rounded-xl p-5">
    <h4 class="font-bold text-red-400 mb-4 flex items-center gap-2 text-base">
      <span class="flex items-center justify-center w-5 h-5 rounded-full bg-red-500/20">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </span>
      Cons
    </h4>
    <ul class="space-y-2.5">
      {cons.map((con) => (
        <li class="flex items-start gap-2.5 text-sm text-zinc-300">
          <svg class="w-4 h-4 text-red-500 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
          <span>{con}</span>
        </li>
      ))}
    </ul>
  </div>
</div>
