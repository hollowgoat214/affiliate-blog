---
import BaseLayout from './BaseLayout.astro';
import AffiliateCard from '../components/AffiliateCard.astro';
import ProsCons from '../components/ProsCons.astro';

interface AffiliateProduct {
  name: string;
  description: string;
  image: string;
  url: string;
  price?: string;
  badge?: string;
}

interface Props {
  title: string;
  description: string;
  heroImage?: string;
  heroImageAlt?: string;
  category: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  placeholder?: boolean;
  affiliateProducts?: AffiliateProduct[];
  pros?: string[];
  cons?: string[];
}

const {
  title, description, heroImage, heroImageAlt,
  category, pubDate, updatedDate, author,
  placeholder = false, affiliateProducts, pros, cons,
} = Astro.props;

const fmt  = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={title} description={description} image={heroImage} type="article" pubDate={pubDate.toISOString()}>
  <article>

    <!-- Hero Image -->
    {heroImage && (
      <div class="w-full overflow-hidden" style="max-height: 480px; background: #0e0e0e;">
        <img
          src={heroImage}
          alt={heroImageAlt || title}
          class="w-full h-full object-cover"
          style="max-height: 480px;"
          loading="eager"
        />
      </div>
    )}

    <div class="container py-12">
      <div class="max-w-[700px] mx-auto">

        <!-- Placeholder banner -->
        {placeholder && (
          <div class="placeholder-banner">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--accent); flex-shrink: 0;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
            <span><strong>Placeholder post.</strong> This is demo content to show how the site looks. Replace with a real review when you're ready.</span>
          </div>
        )}

        <!-- Post header -->
        <header class="mb-10">
          <div class="flex items-center gap-2 mb-5">
            <a href={`/category/${category}`} class="tag">{category}</a>
          </div>

          <h1 class="font-black leading-tight mb-4 tracking-tight" style="font-size: clamp(1.75rem, 4vw, 2.75rem); color: #f0f0f0; line-height: 1.15;">
            {title}
          </h1>

          <p class="text-lg leading-relaxed mb-6" style="color: var(--text-muted);">{description}</p>

          <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs py-4" style="color: var(--text-dim); border-top: 1px solid #1a1a1a; border-bottom: 1px solid #1a1a1a;">
            <span style="color: #555;">{author}</span>
            <span style="color: #2a2a2a;">·</span>
            <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
            {updatedDate && (
              <>
                <span style="color: #2a2a2a;">·</span>
                <span>Updated <time datetime={updatedDate.toISOString()}>{fmt(updatedDate)}</time></span>
              </>
            )}
            <a href="/disclosure" class="ml-auto text-xs transition-colors" style="color: #333;" onmouseover="this.style.color='#f59e0b'" onmouseout="this.style.color='#333'">
              ⓘ Affiliate links
            </a>
          </div>
        </header>

        <!-- Article body -->
        <div class="post-body">
          <slot />
        </div>

        <!-- Pros / Cons -->
        {pros && cons && pros.length > 0 && cons.length > 0 && (
          <div class="mt-12">
            <h2 class="font-black text-xl mb-5 tracking-tight" style="color: #e8e8e8;">Pros &amp; Cons</h2>
            <ProsCons pros={pros} cons={cons} />
          </div>
        )}

        <!-- Affiliate products -->
        {affiliateProducts && affiliateProducts.length > 0 && (
          <div class="mt-14">
            <div class="flex items-end justify-between mb-2">
              <h2 class="font-black text-xl tracking-tight" style="color: #e8e8e8;">Products in this review</h2>
            </div>
            <p class="text-xs mb-6" style="color: var(--text-dim);">
              Affiliate links — I earn a small commission if you buy.
              <a href="/disclosure" class="ml-1 transition-colors" style="color: var(--accent);">Full disclosure →</a>
            </p>
            <div class="space-y-4">
              {affiliateProducts.map((p) => <AffiliateCard {...p} />)}
            </div>
          </div>
        )}

        <!-- Nav -->
        <div class="mt-16 pt-8 flex flex-wrap gap-3" style="border-top: 1px solid #1a1a1a;">
          <a href="/blog" class="btn-ghost">← All Reviews</a>
          <a href={`/category/${category}`} class="btn-ghost">More {category} →</a>
        </div>

      </div>
    </div>
  </article>
</BaseLayout>

<style>
/* Article typography */
.post-body :global(h2) {
  font-size: 1.4rem;
  font-weight: 900;
  letter-spacing: -0.02em;
  color: #efefef;
  margin-top: 2.5rem;
  margin-bottom: 0.875rem;
  line-height: 1.2;
}
.post-body :global(h3) {
  font-size: 1.15rem;
  font-weight: 800;
  color: #e0e0e0;
  margin-top: 2rem;
  margin-bottom: 0.75rem;
}
.post-body :global(p) {
  color: #aaa;
  line-height: 1.8;
  margin-bottom: 1.25rem;
  font-size: 1rem;
}
.post-body :global(a) {
  color: var(--accent);
  text-decoration: none;
  border-bottom: 1px solid rgba(245,158,11,0.3);
  transition: border-color 0.2s, color 0.2s;
}
.post-body :global(a:hover) {
  color: var(--accent-2);
  border-bottom-color: var(--accent);
}
.post-body :global(strong) { color: #d0d0d0; font-weight: 700; }
.post-body :global(em)     { color: #bbb; }
.post-body :global(ul), .post-body :global(ol) {
  margin-bottom: 1.25rem;
  padding-left: 1.5rem;
}
.post-body :global(li) {
  color: #aaa;
  line-height: 1.75;
  margin-bottom: 0.4rem;
}
.post-body :global(blockquote) {
  border-left: 3px solid var(--accent);
  padding-left: 1.25rem;
  margin: 1.5rem 0;
  color: #777;
  font-style: italic;
}
.post-body :global(code) {
  background: #111;
  color: var(--accent);
  padding: 0.15rem 0.45rem;
  border-radius: 4px;
  font-size: 0.875em;
  border: 1px solid #222;
}
.post-body :global(pre) {
  background: #0e0e0e;
  border: 1px solid #222;
  border-radius: 10px;
  padding: 1.25rem;
  overflow-x: auto;
  margin-bottom: 1.5rem;
}
.post-body :global(pre code) {
  background: none;
  border: none;
  padding: 0;
  color: #ccc;
}
.post-body :global(hr) {
  border: none;
  border-top: 1px solid #1f1f1f;
  margin: 2.5rem 0;
}
.post-body :global(table) {
  width: 100%;
  border-collapse: collapse;
  margin-bottom: 1.5rem;
  font-size: 0.9rem;
}
.post-body :global(th) {
  text-align: left;
  font-weight: 700;
  color: #ccc;
  padding: 0.6rem 0.875rem;
  border-bottom: 1px solid #2a2a2a;
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.post-body :global(td) {
  padding: 0.6rem 0.875rem;
  color: #999;
  border-bottom: 1px solid #1a1a1a;
}
.post-body :global(tr:last-child td) { border-bottom: none; }
.post-body :global(img) {
  border-radius: 10px;
  margin: 1.5rem 0;
  max-width: 100%;
}
</style>
