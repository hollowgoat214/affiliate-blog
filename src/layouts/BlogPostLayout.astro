---
import BaseLayout from './BaseLayout.astro';
import AffiliateCard from '../components/AffiliateCard.astro';
import ProsCons from '../components/ProsCons.astro';

interface Product { name:string; description:string; image:string; url:string; price?:string; badge?:string; }

interface Props {
  title: string;
  description: string;
  heroImage?: string;
  heroImageAlt?: string;
  category: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  placeholder?: boolean;
  affiliateProducts?: Product[];
  pros?: string[];
  cons?: string[];
}

const { title, description, heroImage, heroImageAlt, category, pubDate, updatedDate, author, placeholder=false, affiliateProducts, pros, cons } = Astro.props;
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' });
---

<BaseLayout title={title} description={description} image={heroImage} type="article" pubDate={pubDate.toISOString()}>
  <!-- Reading progress bar -->
  <div id="reading-progress"></div>

  <article id="post-article">

    <!-- Hero image -->
    {heroImage && (
      <div style="width:100%;max-height:500px;overflow:hidden;background:var(--surface2);">
        <img
          src={heroImage}
          alt={heroImageAlt || title}
          style={`width:100%;max-height:500px;object-fit:cover;display:block;${placeholder ? 'filter:saturate(0.4) brightness(0.7);' : ''}`}
          loading="eager"
        />
        {placeholder && (
          <div style="position:absolute;top:0;left:0;right:0;bottom:0;display:flex;align-items:center;justify-content:center;pointer-events:none;" aria-hidden="true">
          </div>
        )}
      </div>
    )}

    <div class="container py-14">
      <div style="max-width:720px;margin:0 auto;">

        <!-- Placeholder banner -->
        {placeholder && (
          <div class="placeholder-banner">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" style="flex-shrink:0;margin-top:1px;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
            <div>
              <strong>⚠ THIS IS A PLACEHOLDER POST</strong>
              <br/>
              <span>Demo content to show how the site looks. This is not a real review — replace it with your own when you're ready to launch.</span>
            </div>
          </div>
        )}

        <!-- Post header -->
        <header style="margin-bottom:2.5rem;">
          <div style="margin-bottom:1.25rem;">
            <a href={`/category/${category}`} class="tag">{category}</a>
          </div>

          <h1 style="font-size:clamp(1.8rem,4.5vw,2.9rem);font-weight:900;line-height:1.12;letter-spacing:-.03em;color:#f0ebe3;margin-bottom:1rem;">
            {title}
          </h1>

          <p style="font-size:1.1rem;line-height:1.7;color:var(--muted);margin-bottom:1.5rem;">{description}</p>

          <div style="display:flex;flex-wrap:wrap;align-items:center;gap:.75rem 1.25rem;font-size:.75rem;color:var(--dim);padding:.875rem 0;border-top:1px solid var(--border);border-bottom:1px solid var(--border);">
            <span style="color:var(--muted);font-weight:600;">{author}</span>
            <span style="color:var(--border2);">·</span>
            <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
            {updatedDate && (<><span style="color:var(--border2);">·</span><span>Updated {fmt(updatedDate)}</span></>)}
            <a href="/disclosure" class="hover-dim-link" style="margin-left:auto;font-size:.7rem;">ⓘ Affiliate links</a>
          </div>
        </header>

        <!-- Article body -->
        <div class="post-body">
          <slot/>
        </div>

        <!-- Pros / Cons -->
        {pros && cons && pros.length > 0 && cons.length > 0 && (
          <div style="margin-top:3rem;">
            <h2 style="font-size:1.35rem;font-weight:900;letter-spacing:-.02em;color:#efe9e1;margin-bottom:1.25rem;">Pros &amp; Cons</h2>
            <ProsCons pros={pros} cons={cons}/>
          </div>
        )}

        <!-- Affiliate products -->
        {affiliateProducts && affiliateProducts.length > 0 && (
          <div style="margin-top:3.5rem;">
            <h2 style="font-size:1.35rem;font-weight:900;letter-spacing:-.02em;color:#efe9e1;margin-bottom:.5rem;">Products in this review</h2>
            <p style="font-size:.75rem;color:var(--dim);margin-bottom:1.5rem;">
              Affiliate links — I earn a small commission if you buy through them.
              <a href="/disclosure" class="disclosure-link">Full disclosure →</a>
            </p>
            <div style="display:flex;flex-direction:column;gap:1rem;">
              {affiliateProducts.map(p => <AffiliateCard {...p}/>)}
            </div>
          </div>
        )}

        <!-- Nav -->
        <div style="margin-top:4rem;padding-top:2rem;border-top:1px solid var(--border);display:flex;flex-wrap:wrap;gap:.75rem;">
          <a href="/blog"               class="btn btn-ghost">← All Reviews</a>
          <a href={`/category/${category}`} class="btn btn-ghost">More {category} →</a>
        </div>

      </div>
    </div>
  </article>
</BaseLayout>

<style>
.disclosure-link { color: var(--accent); margin-left: .25rem; transition: opacity .2s; }
.disclosure-link:hover { opacity: .7; }

/* ── Article typography ───────────────────────────── */
.post-body :global(h2) {
  font-size: 1.45rem; font-weight: 900; letter-spacing: -.025em;
  color: #efe9e1; margin: 2.5rem 0 .875rem; line-height: 1.2;
}
.post-body :global(h3) {
  font-size: 1.15rem; font-weight: 800;
  color: #ddd8d0; margin: 2rem 0 .75rem;
}
.post-body :global(p) {
  color: #a09888; line-height: 1.85; margin-bottom: 1.25rem; font-size: 1rem;
}
.post-body :global(a) {
  color: var(--accent); text-decoration: none;
  border-bottom: 1px solid rgba(232,160,32,.3);
  transition: border-color .2s, color .2s;
}
.post-body :global(a:hover) { color: var(--accent2); border-bottom-color: var(--accent); }
.post-body :global(strong)  { color: #d8d0c4; font-weight: 700; }
.post-body :global(ul), .post-body :global(ol) { margin-bottom: 1.25rem; padding-left: 1.5rem; }
.post-body :global(li) { color: #a09888; line-height: 1.8; margin-bottom: .35rem; }
.post-body :global(blockquote) {
  border-left: 3px solid var(--accent); padding-left: 1.25rem;
  margin: 1.75rem 0; color: #6e6560; font-style: italic;
}
.post-body :global(code) {
  background: #111009; color: var(--accent); padding: .15rem .45rem;
  border-radius: 4px; font-size: .875em; border: 1px solid var(--border2);
}
.post-body :global(pre) {
  background: #0e0d0b; border: 1px solid var(--border); border-radius: 10px;
  padding: 1.25rem; overflow-x: auto; margin-bottom: 1.5rem;
}
.post-body :global(pre code)  { background: none; border: none; padding: 0; color: #c0b8ad; }
.post-body :global(hr)        { border: none; border-top: 1px solid var(--border); margin: 2.75rem 0; }
.post-body :global(table)     { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; font-size: .88rem; }
.post-body :global(th)        { text-align: left; font-weight: 800; color: #c8c0b8; padding: .6rem .875rem; border-bottom: 1px solid var(--border2); font-size: .72rem; text-transform: uppercase; letter-spacing: .06em; }
.post-body :global(td)        { padding: .6rem .875rem; color: #8a8278; border-bottom: 1px solid var(--border); }
.post-body :global(tr:last-child td) { border-bottom: none; }
.post-body :global(img)       { border-radius: 10px; margin: 1.5rem 0; max-width: 100%; }
</style>

<script>
  // Reading progress
  const bar     = document.getElementById('reading-progress');
  const article = document.getElementById('post-article');
  if (bar && article) {
    window.addEventListener('scroll', () => {
      const scrolled  = window.scrollY;
      const total     = article.offsetHeight - window.innerHeight;
      const pct       = Math.min(Math.max(scrolled / total, 0), 1);
      bar.style.width = `${pct * 100}%`;
    }, { passive: true });
  }
</script>
