---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import Marquee from '../components/Marquee.astro';
import { getCollection } from 'astro:content';

const all      = await getCollection('blog');
const sorted   = all.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featured = sorted.filter(p => p.data.featured).slice(0, 3);
const recent   = sorted.slice(0, 6);

const cats = [
  { name:'Tech',      icon:'💻', blurb:'Gadgets, audio gear, software'   },
  { name:'Trending',  icon:'🔥', blurb:"What's worth the hype right now" },
  { name:'Gear',      icon:'🎒', blurb:'Tools, EDC, accessories'          },
  { name:'Lifestyle', icon:'✦',  blurb:'Home, health, quality of life'    },
];
---

<BaseLayout
  title="Home"
  description="Tumbleweed0220 — solo affiliate blog. Honest product takes across tech, gear, and lifestyle."
>

  <!-- ── Hero ───────────────────────────────────────────────── -->
  <section style="position:relative;overflow:hidden;border-bottom:1px solid var(--border);padding:6rem 0 5rem;background:var(--surface);">
    <!-- Dot grid — fades toward left -->
    <div class="dot-grid" style="mask-image:radial-gradient(ellipse 70% 100% at 85% 50%,black 0%,transparent 100%);-webkit-mask-image:radial-gradient(ellipse 70% 100% at 85% 50%,black 0%,transparent 100%);"></div>

    <div class="container" style="position:relative;">
      <div class="reveal" style="max-width:680px;">

        <div style="display:inline-flex;align-items:center;gap:.5rem;margin-bottom:1.75rem;font-family:var(--mono);font-size:.58rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--accent);">
          <span style="width:5px;height:5px;border-radius:50%;background:var(--accent);animation:blink 1.4s step-end infinite;display:inline-block;flex-shrink:0;"></span>
          Solo Affiliate Blog
        </div>

        <h1 style="font-size:clamp(2.8rem,7vw,5.5rem);font-weight:900;line-height:1.04;letter-spacing:-.04em;color:var(--text);margin-bottom:1.5rem;">
          Find what's actually<br/>
          <span style="color:var(--accent);">worth&nbsp;buying.</span>
        </h1>

        <p style="font-size:1.1rem;line-height:1.8;color:var(--muted);max-width:480px;margin-bottom:2.25rem;">
          No editorial team. No brand deals. One person's honest take on tech, gear, and the stuff that earns a place in real life.
        </p>

        <div style="display:flex;flex-wrap:wrap;gap:.75rem;">
          <a href="/blog" class="btn btn-primary">
            Browse Reviews
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="/about" class="btn btn-ghost">About the site</a>
        </div>
      </div>

      <!-- Stats -->
      <div class="reveal reveal-delay-3" style="display:flex;flex-wrap:wrap;gap:2rem 3rem;margin-top:4rem;padding-top:2rem;border-top:1px solid var(--border);">
        {[
          { n: '3',    label: 'Reviews live' },
          { n: '100%', label: 'Disclosed links' },
          { n: '1',    label: 'Author' },
        ].map(s => (
          <div>
            <div style="font-family:var(--mono);font-size:1.5rem;font-weight:700;color:var(--text);letter-spacing:-.02em;">{s.n}</div>
            <div style="font-family:var(--mono);font-size:.56rem;font-weight:700;color:var(--dim);text-transform:uppercase;letter-spacing:.14em;margin-top:.3rem;">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Marquee ─────────────────────────────────────────────── -->
  <Marquee/>

  <!-- ── Featured (asymmetric) ──────────────────────────────── -->
  {featured.length > 0 && (
    <section style="padding:5rem 0;border-bottom:1px solid var(--border);">
      <div class="container">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;" class="reveal">
          <div class="section-label">Featured</div>
          <a href="/blog" class="hover-dim-link" style="font-size:.75rem;font-weight:700;">
            All posts →
          </a>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;" class="featured-grid">
          <!-- Big post -->
          {featured[0] && (
            <article class="post-card reveal" data-magnetic style="grid-row:span 2;">
              {featured[0].data.heroImage && (
                <a href={`/blog/${featured[0].slug}`} class="post-card-img block" style="aspect-ratio:16/9;display:block;">
                  <img src={featured[0].data.heroImage} alt={featured[0].data.heroImageAlt||featured[0].data.title} width="800" height="450" loading="eager" style={featured[0].data.placeholder ? 'filter:saturate(.4) brightness(.7);' : ''}/>
                  {featured[0].data.placeholder && (
                    <div class="placeholder-ribbon">⚠ placeholder · demo content · not a real review ⚠</div>
                  )}
                </a>
              )}
              <div style="padding:1.5rem;display:flex;flex-direction:column;flex:1;">
                <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.875rem;">
                  <a href={`/category/${featured[0].data.category}`} class="tag">{featured[0].data.category}</a>
                  <time style="font-size:.7rem;color:var(--dim);margin-left:auto;">{featured[0].data.pubDate.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}</time>
                </div>
                <h3 style="font-size:1.35rem;font-weight:900;line-height:1.2;letter-spacing:-.025em;color:var(--text);margin-bottom:.75rem;">
                  <a href={`/blog/${featured[0].slug}`} class="hover-amber-link">{featured[0].data.title}</a>
                </h3>
                <p style="font-size:.875rem;line-height:1.7;color:var(--muted);flex:1;">{featured[0].data.description}</p>
                <a href={`/blog/${featured[0].slug}`} style="margin-top:1.25rem;font-size:.78rem;font-weight:800;color:var(--accent);text-decoration:none;">Read more →</a>
              </div>
            </article>
          )}

          <!-- Two stacked -->
          {featured.slice(1,3).map((post, i) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug}
              heroImage={post.data.heroImage}
              heroImageAlt={post.data.heroImageAlt}
              category={post.data.category}
              pubDate={post.data.pubDate}
              placeholder={post.data.placeholder}
              index={i+1}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── Categories ─────────────────────────────────────────── -->
  <section style="padding:5rem 0;border-bottom:1px solid var(--border);">
    <div class="container">
      <div class="section-label reveal" style="margin-bottom:2rem;">Categories</div>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;" class="cats-grid">
        {cats.map((c, i) => (
          <a
            href={`/category/${c.name}`}
            class={`cat-card reveal reveal-delay-${i+1}`}
          >
            <div style="font-size:1.75rem;margin-bottom:.75rem;">{c.icon}</div>
            <div style="font-size:.9rem;font-weight:800;color:var(--text);margin-bottom:.3rem;" class="cat-name">{c.name}</div>
            <div style="font-size:.75rem;color:var(--dim);">{c.blurb}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Latest posts ────────────────────────────────────────── -->
  <section style="padding:5rem 0;border-bottom:1px solid var(--border);">
    <div class="container">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;" class="reveal">
        <div class="section-label">Latest</div>
        <a href="/blog" class="hover-dim-link" style="font-size:.75rem;font-weight:700;">
          View all →
        </a>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.25rem;">
        {recent.map((post, i) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            slug={post.slug}
            heroImage={post.data.heroImage}
            heroImageAlt={post.data.heroImageAlt}
            category={post.data.category}
            pubDate={post.data.pubDate}
            placeholder={post.data.placeholder}
            index={i}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ────────────────────────────────────────────────── -->
  <section style="padding:5rem 0;">
    <div class="container">
      <div class="reveal cta-block">
        <!-- dot grid accent -->
        <div class="dot-grid" style="opacity:.4;mask-image:radial-gradient(ellipse 80% 100% at 50% 50%,black 0%,transparent 100%);-webkit-mask-image:radial-gradient(ellipse 80% 100% at 50% 50%,black 0%,transparent 100%);"></div>
        <div style="position:relative;text-align:center;">
          <div class="section-label" style="justify-content:center;margin-bottom:1.25rem;">No newsletter. No spam.</div>
          <h2 style="font-size:clamp(1.5rem,4vw,2.5rem);font-weight:900;letter-spacing:-.03em;color:var(--text);margin-bottom:1rem;">New reviews as I write them.</h2>
          <p style="color:var(--muted);font-size:.9rem;max-width:360px;margin:0 auto 2rem;line-height:1.75;">
            Bookmark it and check back. Or search when you're about to buy something and want a second opinion.
          </p>
          <a href="/blog" class="btn btn-primary">
            See All Reviews
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .cat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    text-decoration: none;
    transition: border-color .22s ease, box-shadow .22s ease, transform .22s var(--ease-calm);
    box-shadow: 0 1px 4px rgba(0,0,0,.04);
  }
  .cat-card:hover {
    border-color: var(--accent);
    box-shadow: 0 8px 20px -6px rgba(0,0,0,.10), 0 0 0 1px var(--accent);
    transform: translateY(-3px);
  }
  .cta-block {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 4rem 3rem;
    position: relative;
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(0,0,0,.04);
  }
  @media (max-width: 640px) {
    .featured-grid { grid-template-columns: 1fr !important; }
    .cats-grid     { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 768px) {
    .cats-grid { grid-template-columns: repeat(4, 1fr) !important; }
  }
</style>
