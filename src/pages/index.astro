---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import Marquee from '../components/Marquee.astro';
import { getCollection } from 'astro:content';

const all      = await getCollection('blog');
const sorted   = all.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featured = sorted.filter(p => p.data.featured).slice(0, 3);
const recent   = sorted.slice(0, 6);

const cats = [
  { name:'Tech',      icon:'💻', blurb:'Gadgets, audio gear, software'   },
  { name:'Trending',  icon:'🔥', blurb:"What's worth the hype right now" },
  { name:'Gear',      icon:'🎒', blurb:'Tools, EDC, accessories'          },
  { name:'Lifestyle', icon:'✦',  blurb:'Home, health, quality of life'    },
];
---

<BaseLayout
  title="Home"
  description="Tumbleweed0220 — solo affiliate blog. Honest product takes across tech, gear, and lifestyle."
>

  <!-- ── Hero ───────────────────────────────────────────────── -->
  <section style="position:relative;overflow:hidden;border-bottom:1px solid var(--border);padding:6rem 0 5rem;">
    <!-- Orbs -->
    <div class="orb" style="width:700px;height:700px;background:radial-gradient(circle,rgba(232,160,32,.07) 0%,transparent 65%);top:-250px;left:-150px;"></div>
    <div class="orb" style="width:400px;height:400px;background:radial-gradient(circle,rgba(232,160,32,.05) 0%,transparent 65%);bottom:-100px;right:-50px;animation-delay:2.5s;"></div>

    <div class="container" style="position:relative;">
      <div class="reveal" style="max-width:780px;">

        <div style="display:inline-flex;align-items:center;gap:.5rem;margin-bottom:1.5rem;font-size:.65rem;font-weight:900;letter-spacing:.18em;text-transform:uppercase;color:var(--accent);">
          <span style="width:6px;height:6px;border-radius:50%;background:var(--accent);animation:pulse-glow 2s ease-in-out infinite;display:inline-block;"></span>
          Solo Affiliate Blog
        </div>

        <h1 style="font-size:clamp(2.6rem,7vw,5.5rem);font-weight:900;line-height:1.04;letter-spacing:-.04em;color:#f0ebe3;margin-bottom:1.5rem;">
          Find what's actually<br/>
          <span style="color:var(--accent);">worth&nbsp;buying.</span>
        </h1>

        <p style="font-size:1.15rem;line-height:1.75;color:var(--muted);max-width:520px;margin-bottom:2rem;">
          No editorial team. No brand deals. One person's honest take on tech, gear, and the stuff that earns a place in real life.
        </p>

        <div style="display:flex;flex-wrap:wrap;gap:.75rem;">
          <a href="/blog"  class="btn btn-primary" style="font-size:.95rem;padding:.75rem 1.75rem;">
            Browse Reviews
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="/about" class="btn btn-ghost" style="font-size:.95rem;padding:.75rem 1.75rem;">About the site</a>
        </div>
      </div>

      <!-- Floating stats -->
      <div class="reveal reveal-delay-3" style="display:flex;gap:2.5rem;margin-top:3.5rem;padding-top:2rem;border-top:1px solid var(--border);">
        {[
          { n: '3',   label: 'Reviews live' },
          { n: '100%', label: 'Disclosed affiliate links' },
          { n: '1',   label: 'Person writing this' },
        ].map(s => (
          <div>
            <div style="font-size:1.6rem;font-weight:900;color:var(--accent);letter-spacing:-.04em;">{s.n}</div>
            <div style="font-size:.7rem;font-weight:600;color:var(--dim);text-transform:uppercase;letter-spacing:.08em;margin-top:.2rem;">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Marquee ─────────────────────────────────────────────── -->
  <Marquee/>

  <!-- ── Featured (asymmetric) ──────────────────────────────── -->
  {featured.length > 0 && (
    <section style="padding:5rem 0;border-bottom:1px solid var(--border);">
      <div class="container">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;" class="reveal">
          <div class="section-label">Featured</div>
          <a href="/blog" style="font-size:.75rem;font-weight:700;color:var(--dim);text-decoration:none;transition:color .2s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--dim)'">
            All posts →
          </a>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;" class="featured-grid">
          <!-- Big post -->
          {featured[0] && (
            <article class="post-card magnetic reveal" data-magnetic style="grid-row:span 2;">
              {featured[0].data.heroImage && (
                <a href={`/blog/${featured[0].slug}`} class="post-card-img block" style="aspect-ratio:16/9;display:block;">
                  <img src={featured[0].data.heroImage} alt={featured[0].data.heroImageAlt||featured[0].data.title} width="800" height="450" loading="eager" style={featured[0].data.placeholder ? 'filter:saturate(.4) brightness(.7);' : ''}/>
                  {featured[0].data.placeholder && (
                    <div class="placeholder-ribbon">⚠ placeholder · demo content · not a real review ⚠</div>
                  )}
                </a>
              )}
              <div style="padding:1.5rem;display:flex;flex-direction:column;flex:1;">
                <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.875rem;">
                  <a href={`/category/${featured[0].data.category}`} class="tag">{featured[0].data.category}</a>
                  <time style="font-size:.7rem;color:var(--dim);margin-left:auto;">{featured[0].data.pubDate.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}</time>
                </div>
                <h3 style="font-size:1.35rem;font-weight:900;line-height:1.2;letter-spacing:-.025em;color:#e8e2da;margin-bottom:.75rem;" class="hover-amber-parent">
                  <a href={`/blog/${featured[0].slug}`} style="transition:color .2s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='#e8e2da'">{featured[0].data.title}</a>
                </h3>
                <p style="font-size:.875rem;line-height:1.7;color:var(--muted);flex:1;">{featured[0].data.description}</p>
                <a href={`/blog/${featured[0].slug}`} style="margin-top:1.25rem;font-size:.78rem;font-weight:800;color:var(--accent);text-decoration:none;">Read more →</a>
              </div>
            </article>
          )}

          <!-- Two stacked -->
          {featured.slice(1,3).map((post, i) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug}
              heroImage={post.data.heroImage}
              heroImageAlt={post.data.heroImageAlt}
              category={post.data.category}
              pubDate={post.data.pubDate}
              placeholder={post.data.placeholder}
              index={i+1}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── Categories ─────────────────────────────────────────── -->
  <section style="padding:5rem 0;border-bottom:1px solid var(--border);">
    <div class="container">
      <div class="section-label reveal" style="margin-bottom:2rem;">Categories</div>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;" class="cats-grid">
        {cats.map((c, i) => (
          <a
            href={`/category/${c.name}`}
            class={`reveal reveal-delay-${i+1}`}
            style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;text-decoration:none;transition:border-color .3s,background .3s,transform .3s cubic-bezier(.16,1,.3,1);"
            onmouseover="this.style.borderColor='rgba(232,160,32,.35)';this.style.background='var(--surface2)';this.style.transform='translateY(-4px)';"
            onmouseout="this.style.borderColor='var(--border)';this.style.background='var(--surface)';this.style.transform='';"
          >
            <div style="font-size:1.75rem;margin-bottom:.75rem;">{c.icon}</div>
            <div style="font-size:.9rem;font-weight:800;color:#e0d8cf;margin-bottom:.3rem;transition:color .2s;" class="cat-name">{c.name}</div>
            <div style="font-size:.75rem;color:var(--dim);">{c.blurb}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Latest posts ────────────────────────────────────────── -->
  <section style="padding:5rem 0;border-bottom:1px solid var(--border);">
    <div class="container">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;" class="reveal">
        <div class="section-label">Latest</div>
        <a href="/blog" style="font-size:.75rem;font-weight:700;color:var(--dim);text-decoration:none;transition:color .2s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--dim)'">
          View all →
        </a>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.25rem;">
        {recent.map((post, i) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            slug={post.slug}
            heroImage={post.data.heroImage}
            heroImageAlt={post.data.heroImageAlt}
            category={post.data.category}
            pubDate={post.data.pubDate}
            placeholder={post.data.placeholder}
            index={i}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ────────────────────────────────────────────────── -->
  <section style="padding:5rem 0;">
    <div class="container">
      <div class="reveal" style="background:var(--surface);border:1px solid var(--border);border-radius:1.25rem;padding:4rem 3rem;text-align:center;position:relative;overflow:hidden;">
        <div class="orb" style="width:500px;height:300px;background:radial-gradient(ellipse,rgba(232,160,32,.06) 0%,transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;"></div>
        <div style="position:relative;">
          <div class="section-label" style="justify-content:center;margin-bottom:1.25rem;">No newsletter. No spam.</div>
          <h2 style="font-size:clamp(1.5rem,4vw,2.5rem);font-weight:900;letter-spacing:-.03em;color:#f0ebe3;margin-bottom:1rem;">New reviews as I write them.</h2>
          <p style="color:var(--muted);font-size:.9rem;max-width:380px;margin:0 auto 2rem;line-height:1.7;">
            Bookmark it and check back. Or just search when you're about to buy something and want a second opinion.
          </p>
          <a href="/blog" class="btn btn-primary" style="font-size:.95rem;padding:.8rem 2.25rem;">
            See All Reviews
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  @media (max-width: 640px) {
    .featured-grid { grid-template-columns: 1fr !important; }
    .cats-grid     { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 768px) {
    .cats-grid { grid-template-columns: repeat(4, 1fr) !important; }
  }
</style>
