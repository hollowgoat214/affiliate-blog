---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const all   = await getCollection('blog');
const posts = all.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const cats  = ['Tech', 'Trending', 'Gear', 'Lifestyle'] as const;
---

<BaseLayout
  title="All Reviews"
  description="Every post on Tumbleweed0220 — product reviews, buying guides, and honest takes."
>
  <section class="py-14">
    <div class="container">

      <header class="mb-10 reveal">
        <h1 class="font-black text-4xl tracking-tight mb-2" style="color:var(--text);">All Reviews</h1>
        <p style="color:var(--muted);" class="text-base">
          {posts.length} post{posts.length !== 1 ? 's' : ''}.
        </p>

        <!-- Category tabs -->
        <div class="flex flex-wrap gap-2 mt-5">
          <a href="/blog" class="tag" style="background:var(--accent-dim);color:var(--accent);border-color:var(--accent);">All</a>
          {cats.map((c) => (
            <a href={`/category/${c}`} class="tag">{c}</a>
          ))}
        </div>
      </header>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {posts.map((post, i) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            slug={post.slug}
            heroImage={post.data.heroImage}
            heroImageAlt={post.data.heroImageAlt}
            category={post.data.category}
            pubDate={post.data.pubDate}
            placeholder={post.data.placeholder}
            index={i}
          />
        ))}
      </div>

    </div>
  </section>
</BaseLayout>
